@{
    ViewData["Title"] = "Inicio";
}

<div class="hero-box position-relative overflow-hidden">
    <div class="orbit-line orbit-1"></div>
    <div class="orbit-line orbit-2"></div>
    <div class="orbit-line orbit-3"></div>
    <div class="planet-dot"></div>

    <h1 class="hero-title">Sistema de Interacción Gravitacional</h1>
    <p class="hero-text mt-3">
        Plataforma para registrar cuerpos celestes, consultar sus propiedades físicas y administrar
        información orbital en un entorno visual inspirado en paneles astronómicos y simulación espacial.
    </p>

    <div class="mt-4 d-flex gap-3 flex-wrap">
        <a asp-controller="CelestialBodies" asp-action="Index" class="btn btn-primary btn-lg">
            Ver cuerpos celestes
        </a>
        <a asp-controller="CelestialBodies" asp-action="Create" class="btn btn-success btn-lg">
            Agregar nuevo cuerpo
        </a>
    </div>
</div>

<div class="row section-space g-4">
    <div class="col-md-4">
        <div class="glass-panel h-100">
            <h4>Registro orbital</h4>
            <p class="text-muted">
                Almacena masa, posición, velocidad y tipo de cada cuerpo celeste.
            </p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="glass-panel h-100">
            <h4>Gestión CRUD</h4>
            <p class="text-muted">
                Crea, consulta, edita y elimina información de forma sencilla y estructurada.
            </p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="glass-panel h-100">
            <h4>Enfoque temático</h4>
            <p class="text-muted">
                Interfaz inspirada en diagramas gravitacionales y sistemas astronómicos.
            </p>
        </div>
    </div>
</div>