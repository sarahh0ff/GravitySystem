@model IEnumerable<GravitySystem.Models.CelestialBody>

@{
    ViewData["Title"] = "Cuerpos Celestes";
}

<div class="glass-panel">
    <h1 class="page-title">Cuerpos Celestes</h1>
    <p class="page-subtitle">
        Registro visual de cuerpos astronómicos para el sistema de interacción gravitacional.
    </p>

    <p>
        <a asp-action="Create" class="btn btn-success">+ Agregar cuerpo celeste</a>
    </p>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Masa</th>
                    <th>Posición X</th>
                    <th>Posición Y</th>
                    <th>Velocidad X</th>
                    <th>Velocidad Y</th>
                    <th>Tipo</th>
                    <th>Activo</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.Mass</td>
                        <td>@item.PositionX</td>
                        <td>@item.PositionY</td>
                        <td>@item.VelocityX</td>
                        <td>@item.VelocityY</td>
                        <td>@item.Type</td>
                        <td>@item.IsActive</td>
                        <td class="d-flex gap-2 flex-wrap">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Detalles</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Eliminar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>